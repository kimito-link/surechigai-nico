{
  "expo": {
    "name": "すれちがいライト",
    "slug": "surechigai",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "surechigai",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f7f1e7"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.surechigai.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationAlwaysAndWhenInUseUsageDescription": "すれ違い検出のためバックグラウンドでも位置情報を使用します 位置情報は約500mのエリアに丸めて表示され 正確な場所が他のユーザーに知られることはありません",
        "NSLocationWhenInUseUsageDescription": "すれ違い検出のため位置情報を使用します",
        "UIBackgroundModes": [
          "location",
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.surechigai.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#f7f1e7"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "すれ違い検出のためバックグラウンドでも位置情報を使用します",
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#4A90D9"
        }
      ],
      "expo-asset",
      "expo-font"
    ]
  }
}
