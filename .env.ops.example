# ops スクリプト用 環境変数テンプレート
# ------------------------------------------------------------
# 使い方:
#   cp .env.ops.example .env.ops
#   .env.ops を編集して値を貼り付け
#   source .env.ops
# 値は 1Password / Bitwarden / メモアプリから都度コピーする前提。
# `.env.ops` 本体は .gitignore で除外済み（コミットされない）。
# ------------------------------------------------------------

# Basic 認証（Vercel の Environment Variables と同じ値）
export ADMIN_USER=""
export ADMIN_PASS=""

# Vercel Cron が使う Bearer（apply モード専用）
export CRON_SECRET=""

# 本番ドメイン（プレビュー叩く時はここを差し替え）
export VERCEL_HOST="https://surechigai-nico.link"
