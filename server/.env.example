# Clerk 認証（Twitter連携）
# https://dashboard.clerk.com で取得
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx

# Clerk リダイレクト設定
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Database (MySQL 8.0+)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=surechigai

# Spotify Web API
# https://developer.spotify.com/dashboard で取得
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# 管理画面 Basic認証
ADMIN_USER=your_admin_user
ADMIN_PASS=your_admin_password

# 公開Webのオリジン（末尾スラッシュなし・www なし）— /chokaigi の canonical に使用
NEXT_PUBLIC_SITE_ORIGIN=https://api.surechigai.app

# お問い合わせメールアドレス
CONTACT_EMAIL=your_email@example.com

# Firebase Admin (FCM push通知用 / 未実装)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
