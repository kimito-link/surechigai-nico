# Clerk 認証（Twitter連携）
# https://dashboard.clerk.com で取得
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx

# Clerk リダイレクト設定
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Production tips (Vercel + Cloudflare DNS)
# - NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY / CLERK_SECRET_KEY は本番用キーを設定
# - Clerk カスタムドメインを使う場合、Cloudflare の CNAME は "DNS only"（灰色雲）にする
# - NEXT_PUBLIC_CLERK_PROXY_URL は設定しない（本リポジトリは Clerk 直結構成）

# Database (MySQL 8.0+)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=surechigai

# Spotify Web API
# https://developer.spotify.com/dashboard で取得
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# 管理画面 Basic認証
ADMIN_USER=your_admin_user
ADMIN_PASS=your_admin_password

# 公開Webのオリジン（末尾スラッシュなし・www なし）— /chokaigi の canonical に使用
NEXT_PUBLIC_SITE_ORIGIN=https://api.surechigai.app

# お問い合わせメールアドレス
CONTACT_EMAIL=your_email@example.com

# Firebase Admin (FCM push通知用 / 未実装)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# -----------------------------------------------
# Upstash Redis（ライブマップキャッシュ用）
# https://console.upstash.com → surechigai-chokaigi → Details
# -----------------------------------------------

# RedisのエンドポイントURL（Upstashダッシュボードの UPSTASH_REDIS_REST_URL）
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io

# Redisへのアクセストークン（Upstashダッシュボードの UPSTASH_REDIS_REST_TOKEN）
# ※ 👁アイコンで表示してからコピーすること
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# -----------------------------------------------
# ゆっくり解説（/api/yukkuri-explain）
# -----------------------------------------------

# OpenRouter — Ollama 未設定時、または Ollama 失敗時のフォールバック
OPENROUTER_API_KEY=

# Ollama（OpenAI 互換 /v1）— ローカル or Cloudflare Tunnel の https
# 例: ollama pull llama3.1:70b-instruct-q4_K_M
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=
# 70B などは 120000〜300000 推奨（ミリ秒）
OLLAMA_TIMEOUT_MS=120000
# 未設定時は Bearer ollama。手前で認証プロキシを挟む場合のみ設定
OLLAMA_API_KEY=

# X プロフィールを LLM に渡す（任意）
TWITTER_BEARER_TOKEN=

# -----------------------------------------------
# VOICEVOX（ゆっくり解説の読み上げ）
# エンジン: https://voicevox.hiroshiba.jp/ 既定 http://127.0.0.1:50021
# -----------------------------------------------
VOICEVOX_BASE_URL=http://127.0.0.1:50021
# 話者ID（未設定時: りんく=ずんだもん3 / こん太=めたん2 / たぬ姉=つむぎ8）
VOICEVOX_SPEAKER_RINK=
VOICEVOX_SPEAKER_KONTA=
VOICEVOX_SPEAKER_TANUNEE=
