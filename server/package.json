{
  "name": "surechigai-server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3002",
    "dev:clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && next dev --port 3002",
    "build": "next build",
    "start": "next start --port 3002",
    "test": "node --test tests/*.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:desktop": "playwright test --project=desktop-chrome",
    "test:e2e:smoke": "playwright test e2e/chokaigi-smoke.spec.ts",
    "test:e2e:flow": "playwright test e2e/chokaigi-flow.spec.ts",
    "test:e2e:monkey": "playwright test e2e/chokaigi-monkey.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "matcher": "npx tsx src/cron/matcher.ts"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "mysql2": "^3.11.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
