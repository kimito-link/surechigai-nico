{
  "name": "surechigai-server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && next dev --port 3010",
    "dev:3011": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && next dev --port 3011",
    "dev:clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && next dev --port 3010",
    "build": "node -r dotenv/config scripts/ensure-chokaigi-tables.mjs && next build",
    "typecheck": "tsc --noEmit",
    "start": "node scripts/bootstrap-db.js && next start --port 3010",
    "db:init": "node scripts/bootstrap-db.js",
    "db:ensure:chokaigi": "node -r dotenv/config scripts/ensure-chokaigi-tables.mjs",
    "db:backfill:yukkuri-profiles": "node -r dotenv/config scripts/backfill-yukkuri-profiles.mjs",
    "test": "node --test tests/*.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:desktop": "playwright test --project=desktop-chrome",
    "test:e2e:layout": "playwright test e2e/chokaigi-layout.spec.ts",
    "test:e2e:first-view": "playwright test e2e/first-view-responsive.spec.ts",
    "test:e2e:first-view:headed": "playwright test e2e/first-view-responsive.spec.ts --headed --project=desktop-chrome",
    "test:e2e:a11y": "playwright test e2e/a11y-skip-main.spec.ts --project=desktop-chrome",
    "test:e2e:auth-smoke": "playwright test e2e/auth-routes-smoke.spec.ts --project=desktop-chrome",
    "test:e2e:admin-smoke": "playwright test e2e/admin-route-smoke.spec.ts --project=desktop-chrome",
    "test:e2e:smoke": "playwright test e2e/chokaigi-smoke.spec.ts",
    "test:e2e:flow": "playwright test e2e/chokaigi-flow.spec.ts",
    "test:e2e:monkey": "playwright test e2e/chokaigi-monkey.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "matcher": "npx tsx src/cron/matcher.ts",
    "yukkuri:status": "node scripts/check-yukkuri-llm.mjs",
    "preflight": "node scripts/dev-preflight.mjs"
  },
  "dependencies": {
    "@clerk/localizations": "^4.5.2",
    "@clerk/nextjs": "^7.2.3",
    "@geolonia/open-reverse-geocoder": "^0.1.0",
    "@upstash/redis": "^1.37.0",
    "dotenv": "^17.3.1",
    "h3-js": "^4.4.0",
    "mysql2": "^3.11.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
